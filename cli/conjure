#!/usr/bin/env bash
# conjure — unified CLI for the Conjure Claude Code harness kit.
#
# Subcommands:
#   init [new|existing|migrate] [--profile=<stack>] [--dry-run] [target]
#       Scaffold .claude/ for a project.
#   migrate [from-claude|from-cursor|from-aider|from-continue|from-copilot]
#       Migrate an existing AI-assistant config to Conjure format.
#   audit [target]
#       Health-check the .claude/ setup.
#   update [--check|--apply] [target]
#       Update a project's .claude/ to current kit version (with diff preview).
#   refresh-graph [target] [--full|--update]
#       Rebuild/update graphify knowledge graph.
#   install-mcp
#       Install recommended MCP servers.
#   version
#       Print Conjure version.
#   help [<subcommand>]
#       Show help.

set -uo pipefail

CONJURE_HOME="${CONJURE_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
CONJURE_VERSION="$(cat "$CONJURE_HOME/VERSION" 2>/dev/null || echo unknown)"

usage() {
  cat <<EOF
conjure $CONJURE_VERSION — Claude Code harness kit
Home: $CONJURE_HOME

Usage:
  conjure init [new|existing|migrate] [--profile=<stack>] [--overlay=<git-url>] [--dry-run] [target]
  conjure migrate <source> [target]            (sources: from-claude, from-cursor,
                                                from-aider, from-continue, from-copilot)
  conjure audit [target]
  conjure update [--check|--apply|--pr|--cron] [target]
  conjure check [--porcelain] [target]
  conjure resolve [--dry-run] [target]
  conjure adopt [--dry-run] [--force] [--rollback] [--resume] [--start-fresh] [--apply-step <id>] [--update-manifest] [--full-inventory] [target]
  conjure refresh-graph [target] [--full|--update]
  conjure refresh-overlay [target]
  conjure install-mcp
  conjure preflight
  conjure publish [--submit] [--dry-run]
  conjure publish-skill <name> [--to <org/repo>] [--dry-run]
  conjure version
  conjure help [<subcommand>]

Profiles available: $(ls "$CONJURE_HOME/profiles" 2>/dev/null | tr '\n' ' ')

Run 'conjure help <subcommand>' for details.
EOF
}

cmd_version() { echo "conjure $CONJURE_VERSION"; }

cmd_init() {
  local mode="existing" profile="" overlay="" dryrun=0 target="$(pwd)"
  while [ $# -gt 0 ]; do
    case "$1" in
      new|existing|migrate) mode="$1" ;;
      --profile=*)          profile="${1#--profile=}" ;;
      --overlay=*)          overlay="${1#--overlay=}" ;;
      --dry-run)            dryrun=1 ;;
      --help|-h)            grep -A3 '^  conjure init' <<<"$(usage)"; return 0 ;;
      *)                    target="$1" ;;
    esac
    shift
  done
  DRY_RUN="$dryrun"
  source "$CONJURE_HOME/lib/mutate.sh" \
    || { echo "✗ Failed to load lib/mutate.sh — check CONJURE_HOME ($CONJURE_HOME)"; return 1; }

  echo "▸ conjure init: mode=$mode profile=${profile:-none} target=$target dry_run=$dryrun"

  # Pre-flight checks
  cmd_preflight || return 1

  if [ "$mode" = "migrate" ]; then
    cmd_migrate from-claude "$target" "$dryrun"
    return $?
  fi

  CONJURE_HOME="$CONJURE_HOME" DRY_RUN="$dryrun" bash "$CONJURE_HOME/scripts/init-project.sh" "$mode" "$target"

  # Apply stack profile overlay if specified
  if [ -n "$profile" ] && [ -d "$CONJURE_HOME/profiles/$profile" ]; then
    echo "▸ Applying profile: $profile"
    CONJURE_HOME="$CONJURE_HOME" DRY_RUN="$dryrun" bash "$CONJURE_HOME/profiles/$profile/apply.sh" "$target"
  fi

  # Apply org overlay if specified (OVLY-01)
  if [ -n "$overlay" ]; then
    CONJURE_HOME="$CONJURE_HOME" DRY_RUN="$dryrun" \
      bash "$CONJURE_HOME/scripts/init-overlay.sh" "$overlay" "$target"
  fi

  # Stamp version
  mutate_write "$target/.claude/.conjure-version" "$CONJURE_VERSION"

  # Write base snapshot for future 3-way merges (MERGE-02, D-03)
  local snap_dir="$target/.claude/.conjure-templates-${CONJURE_VERSION}"
  mutate_mkdir "$snap_dir"
  mutate_cp "$CONJURE_HOME/templates/CLAUDE.md.tmpl" "$snap_dir/CLAUDE.md.tmpl"
  # Guard against cp -r double-nesting: when dest already exists, cp -r copies src INTO dest
  # producing e.g. skills/skills/. Only copy when the subdirectory does not yet exist.
  if [ ! -d "$snap_dir/skills" ]; then
    mutate_cp "$CONJURE_HOME/templates/skills"       "$snap_dir/skills"
  fi
  if [ ! -d "$snap_dir/agents" ]; then
    mutate_cp "$CONJURE_HOME/templates/agents"       "$snap_dir/agents"
  fi
  if [ ! -d "$snap_dir/hooks" ]; then
    mutate_cp "$CONJURE_HOME/templates/hooks-nodejs" "$snap_dir/hooks"
  fi
  echo "▸ Snapshot written: $snap_dir"

  mutate_summary
  echo "▸ Pinned conjure version: $CONJURE_VERSION"
}

cmd_migrate() {
  local source="${1:-}" target="${2:-$(pwd)}" dryrun="${3:-0}"
  [ -z "$source" ] && { echo "Usage: conjure migrate <source> [target]"; return 1; }

  local script="$CONJURE_HOME/migrations/$source/migrate.sh"
  if [ ! -f "$script" ]; then
    echo "✗ No migration script for source: $source"
    echo "  Available: $(ls "$CONJURE_HOME/migrations" 2>/dev/null | tr '\n' ' ')"
    return 1
  fi

  # Backup target's existing .claude/ before any mutation
  if [ -d "$target/.claude" ]; then
    local ts; ts="$(date +%Y%m%d-%H%M%S)"
    local backup="$target/.claude.backup-$ts"
    echo "▸ Backing up existing .claude/ → $backup"
    [ "$dryrun" = 0 ] && cp -R "$target/.claude" "$backup"
  fi

  CONJURE_HOME="$CONJURE_HOME" DRY_RUN="$dryrun" bash "$script" "$target"
}

cmd_audit() {
  local target="$(pwd)" do_cost=0 do_exact=0 do_retire=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --cost)         do_cost=1 ;;
      --exact)        do_exact=1 ;;
      --retire-list)  do_retire=1 ;;
      --help|-h)      grep -A3 '^  conjure audit' <<<"$(usage)"; return 0 ;;
      *)              target="$1" ;;
    esac
    shift
  done
  cmd_preflight || return 1
  CONJURE_HOME="$CONJURE_HOME" CONJURE_COST="$do_cost" CONJURE_EXACT="$do_exact" \
    CONJURE_RETIRE="$do_retire" \
    bash "$CONJURE_HOME/scripts/audit-setup.sh" "$target"
}

cmd_check() {
  local porcelain=0 target="$(pwd)"
  while [ $# -gt 0 ]; do
    case "$1" in
      --porcelain)  porcelain=1 ;;
      --help|-h)    echo "Usage: conjure check [--porcelain] [target]"; return 0 ;;
      *)            target="$1" ;;
    esac
    shift
  done
  CONJURE_HOME="$CONJURE_HOME" CONJURE_PORCELAIN="$porcelain" \
    bash "$CONJURE_HOME/scripts/check.sh" "$target"
}

cmd_resolve() {
  local target dryrun
  target="$(pwd)"
  dryrun=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run)   dryrun=1 ;;
      --help|-h)   echo "Usage: conjure resolve [--dry-run] [target]"; return 0 ;;
      *)           target="$1" ;;
    esac
    shift
  done
  CONJURE_HOME="$CONJURE_HOME" DRY_RUN="$dryrun" \
    bash "$CONJURE_HOME/scripts/resolve.sh" "$target"
}

cmd_adopt() {
  # Thin wrapper (mirror cmd_resolve/cmd_audit): parse flags → CONJURE_ADOPT_*
  # env vars → exec scripts/adopt.sh. Zero business logic lives here.
  local target dryrun force rollback resume start_fresh apply_step update_manifest full_inv
  target="$(pwd)"; dryrun=0; force=0; rollback=0; resume=0; start_fresh=0
  apply_step=""; update_manifest=0; full_inv=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run)         dryrun=1 ;;
      --force)           force=1 ;;
      --rollback)        rollback=1 ;;
      --resume)          resume=1 ;;
      --start-fresh)     start_fresh=1 ;;
      --apply-step)      shift; apply_step="${1:-}" ;;
      --update-manifest) update_manifest=1 ;;
      --full-inventory)  full_inv=1 ;;
      --help|-h)         echo "Usage: conjure adopt [--dry-run] [--force] [--rollback] [--resume] [--start-fresh] [--apply-step <id>] [--update-manifest] [--full-inventory] [target]"; return 0 ;;
      *)                 target="$1" ;;
    esac
    shift
  done
  cmd_preflight || return 1
  CONJURE_HOME="$CONJURE_HOME" DRY_RUN="$dryrun" \
    CONJURE_ADOPT_FORCE="$force" CONJURE_ADOPT_ROLLBACK="$rollback" \
    CONJURE_ADOPT_RESUME="$resume" CONJURE_ADOPT_START_FRESH="$start_fresh" \
    CONJURE_ADOPT_APPLY_STEP="$apply_step" CONJURE_ADOPT_UPDATE_MANIFEST="$update_manifest" \
    CONJURE_ADOPT_FULL_INVENTORY="$full_inv" \
    bash "$CONJURE_HOME/scripts/adopt.sh" "$target"
}

cmd_update() {
  local action="--check" target="$(pwd)"
  while [ $# -gt 0 ]; do
    case "$1" in
      --check|--apply) action="$1" ;;
      --pr)            action="--pr" ;;
      --cron)          action="--cron" ;;
      --help|-h)       echo "Usage: conjure update [--check|--apply|--pr|--cron] [target]"; return 0 ;;
      *)               target="$1" ;;
    esac
    shift
  done

  # --pr: open a GitHub PR with harness drift applied on a new branch (AUTPR-01)
  if [ "$action" = "--pr" ]; then
    if ! command -v gh >/dev/null 2>&1; then
      echo "✗ gh CLI required for --pr (install: https://cli.github.com)" >&2
      return 2
    fi

    # Zero-drift guard: if no drift, nothing to do
    local check_rc
    CONJURE_HOME="$CONJURE_HOME" bash "$CONJURE_HOME/cli/conjure" check "$target" >/dev/null 2>&1 && check_rc=0 || check_rc=$?
    if [ "$check_rc" -eq 0 ]; then
      echo "Harness is current — no PR needed"
      return 0
    fi

    # Compute deterministic branch name from kit version
    local kit_ver
    kit_ver="$(cat "$CONJURE_HOME/VERSION" 2>/dev/null || echo unknown)"
    local branch_hash
    if command -v sha256sum >/dev/null 2>&1; then
      branch_hash="$(printf '%s' "$kit_ver" | sha256sum | awk '{print $1}')"
    else
      branch_hash="$(printf '%s' "$kit_ver" | shasum -a 256 | awk '{print $1}')"
    fi
    local branch="conjure/update-${branch_hash:0:7}"

    # Idempotency check: if PR already open for this branch, print URL and exit
    local existing
    existing="$(gh pr list --head "$branch" --state open --json url --jq '.[0].url' 2>/dev/null || true)"
    if [ -n "$existing" ]; then
      echo "▸ PR already exists: $existing"
      return 0
    fi

    # Build PR body from porcelain drift output
    local drift_lines
    drift_lines="$(CONJURE_HOME="$CONJURE_HOME" bash "$CONJURE_HOME/cli/conjure" check --porcelain "$target" 2>/dev/null || true)"
    local pr_body
    pr_body="$(printf '%s\n' \
      "## Harness drift detected by \`conjure check\`" \
      "" \
      "| Status | File |" \
      "|--------|------|"
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      local s="${line%% *}"
      local p="${line#* }"
      printf '| %s | `%s` |\n' "$s" "$p"
    done <<< "$drift_lines")"

    # git operations
    git -C "$target" checkout -b "$branch" \
      || { echo "✗ git checkout -b failed"; return 1; }
    CONJURE_HOME="$CONJURE_HOME" bash "$CONJURE_HOME/cli/conjure" update --apply "$target" \
      || { echo "✗ conjure update --apply failed"; return 1; }
    git -C "$target" add -A
    git -C "$target" commit -m "conjure: update harness to v${CONJURE_VERSION}"
    git -C "$target" push origin "$branch" \
      || { echo "✗ git push failed"; return 1; }

    # Open PR
    local pr_url
    pr_url="$(gh pr create \
      --title "conjure: update harness to v${CONJURE_VERSION}" \
      --body "$pr_body" \
      --head "$branch")"
    echo "▸ PR opened: $pr_url"
    return 0
  fi

  # --cron: write GitHub Actions workflow template for weekly auto-update (AUTPR-02)
  if [ "$action" = "--cron" ]; then
    local workflow_dir="$target/.github/workflows"
    mkdir -p "$workflow_dir"
    local wf_file="$workflow_dir/conjure-update.yml"
    cat > "$wf_file" <<'CRONEOF'
name: Conjure harness auto-update
on:
  schedule:
    - cron: '0 9 * * 1'
  workflow_dispatch: {}
jobs:
  conjure-update:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install conjure
        run: |
          curl -fsSL https://raw.githubusercontent.com/mohandoz/conjure/main/install.sh | bash
          echo "$HOME/.local/bin" >> "$GITHUB_PATH"
      - name: Check drift
        id: drift
        run: conjure check || echo "drift=1" >> "$GITHUB_OUTPUT"
      - name: Open update PR
        if: steps.drift.outputs.drift == '1'
        run: conjure update --pr
CRONEOF
    echo "▸ Cron template written: $wf_file"
    return 0
  fi

  local pinned="unknown"
  [ -f "$target/.claude/.conjure-version" ] && pinned="$(cat "$target/.claude/.conjure-version")"

  echo "Project pinned to:  $pinned"
  echo "Current Conjure:    $CONJURE_VERSION"

  if [ "$pinned" = "$CONJURE_VERSION" ]; then
    echo "✓ Up to date"
    return 0
  fi

  # Show diff against current templates
  echo
  echo "▸ Computing diff against current templates..."
  local diff_count=0
  while IFS= read -r f; do
    local rel="${f#$CONJURE_HOME/templates/}"
    local proj="$target/.claude/${rel%/SKILL.md}/SKILL.md"
    if [ -f "$proj" ] && ! diff -q "$f" "$proj" >/dev/null 2>&1; then
      echo "  ~ ${rel%/SKILL.md}/SKILL.md (changed upstream)"
      diff_count=$((diff_count+1))
    fi
  done < <(find "$CONJURE_HOME/templates/skills" -name SKILL.md)

  if [ "$action" = "--check" ]; then
    echo
    echo "$diff_count file(s) differ. Run 'conjure update --apply' to interactively merge."
    echo "Backup-before-mutate is automatic."
    return 0
  fi

  # --apply: real 3-way merge via lib/merge.sh (MERGE-01, D-01)
  source "$CONJURE_HOME/lib/mutate.sh" \
    || { echo "✗ Failed to load lib/mutate.sh — check CONJURE_HOME ($CONJURE_HOME)"; return 1; }
  source "$CONJURE_HOME/lib/merge.sh" \
    || { echo "✗ Failed to load lib/merge.sh — check CONJURE_HOME ($CONJURE_HOME)"; return 1; }

  # Read pinned version from project (already read into $pinned above)
  local snap_dir="$target/.claude/.conjure-templates-${pinned}"

  # D-01: abort if snapshot missing
  if [ ! -d "$snap_dir" ]; then
    echo "✗ No base snapshot for v${pinned}. Re-run 'conjure init' to write one, then update."
    return 1
  fi

  # Backup before any mutation (pattern from cmd_migrate)
  if [ -d "$target/.claude" ]; then
    local ts; ts="$(date +%Y%m%d-%H%M%S)"
    local backup="$target/.claude.backup-${ts}"
    echo "▸ Backing up existing .claude/ → $backup"
    cp -R "$target/.claude" "$backup" \
      || { echo "✗ Backup failed — aborting merge to protect your files."; return 1; }
  fi

  echo "▸ Applying 3-way merge: v${pinned} → v${CONJURE_VERSION}"

  # MERGE-04: generated files — take upstream unconditionally (no 3-way merge)
  if [ -f "$CONJURE_HOME/templates/settings.json.tmpl" ]; then
    mutate_cp "$CONJURE_HOME/templates/settings.json.tmpl" "$target/.claude/settings.json"
    echo "  ✓ settings.json taken from upstream (generated file)"
  fi

  # MERGE-01: user-owned files — 3-way merge via lib/merge.sh
  merge_user_files "$target" "$snap_dir" "$CONJURE_VERSION" "$pinned"
  local merge_rc=$?
  if [ "$merge_rc" -eq 2 ]; then
    echo "✗ Merge aborted due to git error — see messages above"
    return 2
  fi

  # D-06: report conflicts and exit 1; stamp version only on zero conflicts
  if [ "${CONJURE_MERGE_CONFLICT_COUNT:-0}" -gt 0 ]; then
    echo
    echo "✗ Conflicts in the following files:"
    printf '%s\n' "$CONJURE_MERGE_CONFLICT_FILES" | while IFS= read -r sf; do
      [ -z "$sf" ] && continue
      echo "    $sf"
    done
    echo "  Resolve conflicts, delete the .conjure-conflict-* sidecars, then run:"
    echo "  echo '${CONJURE_VERSION}' > $target/.claude/.conjure-version"
    return 1
  fi

  # Clean: stamp new version
  mutate_write "$target/.claude/.conjure-version" "$CONJURE_VERSION"
  mutate_summary
  echo "✓ Updated to v${CONJURE_VERSION}"
}

cmd_refresh_graph() {
  bash "$CONJURE_HOME/scripts/refresh-graph.sh" "$@"
}

cmd_refresh_overlay() {
  bash "$CONJURE_HOME/scripts/refresh-overlay.sh" "$@"
}

cmd_install_mcp() {
  bash "$CONJURE_HOME/scripts/install-mcp-stack.sh"
}

cmd_preflight() {
  bash "$CONJURE_HOME/scripts/preflight.sh"
}

cmd_publish() {
  local do_submit=0
  local dryrun=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --submit)    do_submit=1 ;;
      --dry-run)   dryrun=1 ;;
      --help|-h)   echo "Usage: conjure publish [--submit] [--dry-run]"; return 0 ;;
      *)           echo "Unknown option: $1"; return 1 ;;
    esac
    shift
  done
  CONJURE_HOME="$CONJURE_HOME" DRY_RUN="$dryrun" CONJURE_SUBMIT="$do_submit" \
    bash "$CONJURE_HOME/scripts/publish-plugin.sh"
}

cmd_publish_skill() {
  local skill_name="" target_repo="mohandoz/conjure" dryrun=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --to)        shift; target_repo="${1:-}" ;;
      --to=*)      target_repo="${1#--to=}" ;;
      --dry-run)   dryrun=1 ;;
      --help|-h)   echo "Usage: conjure publish-skill <name> [--to <org/repo>] [--dry-run]"; return 0 ;;
      -*)          echo "Unknown option: $1"; return 1 ;;
      *)           skill_name="$1" ;;
    esac
    shift
  done
  [ -z "$skill_name" ] && {
    echo "Usage: conjure publish-skill <name> [--to <org/repo>] [--dry-run]"
    return 1
  }
  CONJURE_HOME="$CONJURE_HOME" DRY_RUN="$dryrun" TARGET_REPO="$target_repo" \
    bash "$CONJURE_HOME/scripts/publish-skill.sh" "$skill_name"
}

cmd_help() {
  if [ -n "${1:-}" ]; then
    local fn_name
    fn_name="$(printf '%s' "$1" | tr '-' '_')"
    sed -n "/^cmd_${fn_name}()/,/^}/p" "$0" | head -20
  else
    usage
  fi
}

# Dispatch
case "${1:-help}" in
  init)            shift; cmd_init "$@"            ;;
  migrate)         shift; cmd_migrate "$@"         ;;
  audit)           shift; cmd_audit "$@"           ;;
  update)          shift; cmd_update "$@"          ;;
  check)           shift; cmd_check "$@"           ;;
  resolve)         shift; cmd_resolve "$@"         ;;
  adopt)           shift; cmd_adopt "$@"           ;;
  refresh-graph)   shift; cmd_refresh_graph "$@"   ;;
  refresh-overlay) shift; cmd_refresh_overlay "$@" ;;
  install-mcp)     shift; cmd_install_mcp "$@"     ;;
  preflight)       shift; cmd_preflight "$@"       ;;
  publish)         shift; cmd_publish "$@"         ;;
  publish-skill)   shift; cmd_publish_skill "$@"   ;;
  version|-v|--version) cmd_version                ;;
  help|-h|--help)  shift; cmd_help "$@"            ;;
  *)               echo "Unknown command: $1"; usage; exit 1 ;;
esac
